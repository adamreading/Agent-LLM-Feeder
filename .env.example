# ─────────────────────────────────────────────────────────────────────────
# Agent-LLM-Feeder — environment configuration
# Copy to .env and fill in. .env is gitignored; never commit real keys.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — encryption key for API-key storage at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# REQUIRED — Postgres connection string for the feeder database.
# e.g. postgres://user:pass@localhost:5432/feeder
DATABASE_URL=postgres://localhost:5432/feeder

# Server port (default: 3001)
PORT=3001

# ─── Model research (per-model wiki summaries + task scores) ───────────────
# The research job web-searches each model (arena leaderboards + general web)
# and has one of your own models write a summary + per-task quality scores.
# Run on demand:  npm run research   (from server/), or POST /api/canon/:id/research

# Which web-search backend to use for research. Default: ollama.
#   ollama — hosted web_search + web_fetch (OLLAMA_API_KEY). Reliable, but the
#            free tier has hard hourly + weekly caps.
#   ddg    — DuckDuckGo (via duck-duck-scrape) for SEARCH, Ollama for FETCH.
#            Free, no key. NOTE: DDG IP-blocks sustained scraper traffic
#            ("anomaly"), so a datacenter/WSL egress may be blocked outright —
#            fine when the egress isn't flagged, unreliable as a heavy primary.
#   tavily — keyed search API built for LLM research (TAVILY_API_KEY, free tier
#            ~1k/mo). Not IP-scraping, so no anomaly blocking — the reliable
#            primary when a key is available; returns content inline (no Ollama).
# Add more (Brave, SearXNG, …) in server/src/services/webSearch.ts.
WEB_SEARCH_BACKEND=ollama

# API key for the Ollama hosted web-search API (https://ollama.com/settings/keys).
# Required when WEB_SEARCH_BACKEND=ollama (and used as the fetch step for ddg).
OLLAMA_API_KEY=

# API key for Tavily search (https://tavily.com — free tier). Required when
# WEB_SEARCH_BACKEND=tavily.
TAVILY_API_KEY=

# Optional: minimum ms between DDG queries (politeness/backoff). Default 2500.
DDG_MIN_INTERVAL_MS=

# Which model writes the research summaries — pick one strong at writing.
# Format: platform/model_id (e.g. mistral/mistral-large-latest).
# Optional: if unset, feeder auto-picks the smartest json_mode-capable model
# that has a configured key.
RESEARCH_MODEL=

# ── Tier-1 prompt classifier (optional; DISABLED unless CLASSIFIER_OLLAMA_URL set) ──
# When the feeder receives a bare `auto` request (no task_class), it derives a
# task_class from the prompt so routing picks a task-appropriate model. Tier-0
# heuristics (built in, ~0ms) handle the clear cases. Tier-1 is an optional local
# Ollama model that refines only the low-confidence residue.
#
# Leave CLASSIFIER_OLLAMA_URL blank to run tier-0 only (no external dependency).
# To enable tier-1, point it at a LOCAL Ollama and pick a tiny fast model. The URL
# must be the model server's ROOT (the feeder calls the NATIVE /api/chat, which
# honors keep_alive + num_ctx — Ollama's OpenAI-compat /v1 SILENTLY IGNORES both).
# SHARED-BOX SAFETY: tier-1 runs ON-DEMAND by default (keep_alive=0 → the model
# unloads right after each classify, so no idle VRAM footprint between classifies),
# and num_ctx is capped low so even the brief load is small. That, not a warm-model
# floor, is the VRAM discipline. Tier-1 always falls back to tier-0 on timeout.
CLASSIFIER_OLLAMA_URL=
# Fixed classifier model (default llama3.2:3b — 14/14 on the Phase-1 accuracy probe).
CLASSIFIER_MODEL=
# Hard timeout per classify in ms (default 2500 — covers a ~2s cold load; every
# classify is cold when keep_alive=0).
CLASSIFIER_TIMEOUT_MS=
# keep_alive sent to Ollama (default '0' = unload immediately after each classify,
# on-demand, zero idle VRAM). Set e.g. '10s' to trade a little idle VRAM for fewer
# cold loads on bursty traffic.
CLASSIFIER_KEEP_ALIVE=
# num_ctx for the classifier (default 2048). The input is tiny (short few-shot
# prompt + truncated user turn), so a small window keeps the KV-cache footprint low.
CLASSIFIER_NUM_CTX=

# ── Web-search augment (Phase 4) ──
# When a caller opts in, the feeder runs the configured search backend and injects
# results as grounding before routing. Per-request `augment` field (off/auto/force)
# or X-Augment header controls it; the field always overrides these env defaults.
#
# Global DEFAULT for requests that DON'T set the field. 'off' (default) = opt-in:
# nothing augmented unless a caller asks (the provenance-safe posture). Set to
# 'auto' to flip the whole fleet to opt-OUT (bare requests get augmented when the
# prompt needs current info) without a code change.
FEEDER_AUGMENT_DEFAULT=off
# Comma-separated consumer labels HARD-BLOCKED from augmentation regardless of the
# augment field (defence-in-depth for grounded/closed-world callers whose output
# must never contain web content). Default: open-brain (OB's grounded workers).
AUGMENT_BLOCKED_CONSUMERS=open-brain

# ── Agent page filesystem access ─────────────────────────────────────────────
# The Agent UI (/api/agent) browses the HOST filesystem (any absolute path,
# incl. mounted Windows drives). It is authenticated (localhost trusted; remote
# callers need the unified key) and READ-ONLY by default — the write/replace
# endpoint is disabled. Set to 1 to re-enable writes (secret files stay blocked
# either way). Leave unset/0 unless you deliberately want UI-driven file edits.
AGENT_ALLOW_WRITE=0
# How many image thumbs-down on one model (Agent UI feedback) before its vision
# capability is auto-demoted (observed=false → router stops sending it images).
# A later genuine successful image completion re-observes vision=true.
FEEDBACK_VISION_DEMOTE_THRESHOLD=3
