# ─────────────────────────────────────────────────────────────────────────
# Agent-LLM-Feeder — environment configuration
# Copy to .env and fill in. .env is gitignored; never commit real keys.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — encryption key for API-key storage at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# REQUIRED — Postgres connection string for the feeder database.
# e.g. postgres://user:pass@localhost:5432/feeder
DATABASE_URL=postgres://localhost:5432/feeder

# Server port (default: 3001)
PORT=3001

# ─── Model research (per-model wiki summaries + task scores) ───────────────
# The research job web-searches each model (arena leaderboards + general web)
# and has one of your own models write a summary + per-task quality scores.
# Run on demand:  npm run research   (from server/), or POST /api/canon/:id/research
#
# ⚠ AUTHORITATIVE SOURCE IS THE DB, NOT THIS FILE. The active backend + every
# provider key are managed from the web UI ("SEARCH PROVIDERS" card on Onboarding
# AND the Key Vault) and stored in the `settings` table: the active backend id in
# `web_search_backend` (plaintext), each provider's key ENCRYPTED in
# `search_key_<id>` (its OWN row — e.g. the Ollama search key lives in
# `search_key_ollama`, separate from any model key). At boot, on UI update, and at
# CLI-research start, loadSearchConfigIntoEnv() (services/searchConfig.ts) copies
# those DB values into process.env, OVERRIDING whatever is set below. So the vars
# below are a bootstrap fallback only — to see what's LIVE, query `settings`, not
# this file or /proc env (DB values are injected at runtime, never in /proc environ).
#
# The provider catalog is SEARCH_PROVIDER_CATALOG in services/searchConfig.ts (one
# source of truth for server + UI). Add a provider there + a SearchBackend in
# webSearch.ts under the same id. Keyed backends can be tested from the UI with a
# single live query ("VERIFY" button → POST /api/settings/search/verify).

# Which web-search backend to use for research (fallback if the DB has none). Default: ollama.
#   ollama — hosted web_search + web_fetch (OLLAMA_API_KEY). KEYED; free tier has
#            hard hourly + weekly caps.
#   tavily — keyed search built for LLM research (TAVILY_API_KEY, ~1k/mo free).
#            Returns content inline; reliable primary.
#   brave  — Brave Search API (BRAVE_SEARCH_API_KEY, ~2k/mo free). Independent index.
#   serper — Serper.dev Google SERP JSON (SERPER_API_KEY, ~2.5k free credits).
#   exa    — Exa neural/semantic search (EXA_API_KEY); returns page text inline.
#   ddg    — DuckDuckGo (duck-duck-scrape) for SEARCH, Ollama for FETCH. KEYLESS,
#            but DDG IP-blocks sustained scraping — unreliable from a datacenter/WSL egress.
WEB_SEARCH_BACKEND=ollama

# Search-provider keys (bootstrap fallback — normally set in the UI, stored in DB).
OLLAMA_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
EXA_API_KEY=

# Optional: minimum ms between DDG queries (politeness/backoff). Default 2500.
DDG_MIN_INTERVAL_MS=

# Which model writes the research summaries — pick one strong at writing.
# Format: platform/model_id (e.g. mistral/mistral-large-latest).
# Optional: if unset, feeder auto-picks the smartest json_mode-capable model
# that has a configured key.
RESEARCH_MODEL=

# ── Tier-1 prompt classifier (optional; DISABLED unless CLASSIFIER_OLLAMA_URL set) ──
# When the feeder receives a bare `auto` request (no task_class), it derives a
# task_class from the prompt so routing picks a task-appropriate model. Tier-0
# heuristics (built in, ~0ms) handle the clear cases. Tier-1 is an optional local
# Ollama model that refines only the low-confidence residue.
#
# Leave CLASSIFIER_OLLAMA_URL blank to run tier-0 only (no external dependency).
# To enable tier-1, point it at a LOCAL Ollama and pick a tiny fast model. The URL
# must be the model server's ROOT (the feeder calls the NATIVE /api/chat, which
# honors keep_alive + num_ctx — Ollama's OpenAI-compat /v1 SILENTLY IGNORES both).
# SHARED-BOX SAFETY: tier-1 runs ON-DEMAND by default (keep_alive=0 → the model
# unloads right after each classify, so no idle VRAM footprint between classifies),
# and num_ctx is capped low so even the brief load is small. That, not a warm-model
# floor, is the VRAM discipline. Tier-1 always falls back to tier-0 on timeout.
CLASSIFIER_OLLAMA_URL=
# Fixed classifier model (default llama3.2:3b — 14/14 on the Phase-1 accuracy probe).
CLASSIFIER_MODEL=
# Hard timeout per classify in ms (default 2500 — covers a ~2s cold load; every
# classify is cold when keep_alive=0).
CLASSIFIER_TIMEOUT_MS=
# keep_alive sent to Ollama (default '0' = unload immediately after each classify,
# on-demand, zero idle VRAM). Set e.g. '10s' to trade a little idle VRAM for fewer
# cold loads on bursty traffic.
CLASSIFIER_KEEP_ALIVE=
# num_ctx for the classifier (default 2048). The input is tiny (short few-shot
# prompt + truncated user turn), so a small window keeps the KV-cache footprint low.
CLASSIFIER_NUM_CTX=

# ── Web-search augment (Phase 4) ──
# When a caller opts in, the feeder runs the configured search backend and injects
# results as grounding before routing. Per-request `augment` field (off/auto/force)
# or X-Augment header controls it; the field always overrides these env defaults.
#
# Global DEFAULT for requests that DON'T set the field. 'off' (default) = opt-in:
# nothing augmented unless a caller asks (the provenance-safe posture). Set to
# 'auto' to flip the whole fleet to opt-OUT (bare requests get augmented when the
# prompt needs current info) without a code change.
FEEDER_AUGMENT_DEFAULT=off
# Comma-separated consumer labels HARD-BLOCKED from augmentation regardless of the
# augment field (defence-in-depth for grounded/closed-world callers whose output
# must never contain web content). Default: open-brain (OB's grounded workers).
AUGMENT_BLOCKED_CONSUMERS=open-brain

# ── Agent page filesystem access ─────────────────────────────────────────────
# The Agent UI (/api/agent) browses the HOST filesystem (any absolute path,
# incl. mounted Windows drives). It is authenticated (localhost trusted; remote
# callers need the unified key) and READ-ONLY by default — the write/replace
# endpoint is disabled. Set to 1 to re-enable writes (secret files stay blocked
# either way). Leave unset/0 unless you deliberately want UI-driven file edits.
AGENT_ALLOW_WRITE=0
# How many image thumbs-down on one model (Agent UI feedback) before its vision
# capability is auto-demoted (observed=false → router stops sending it images).
# A later genuine successful image completion re-observes vision=true.
FEEDBACK_VISION_DEMOTE_THRESHOLD=3
# Weight of NON-image thumbs feedback as a general routing nudge (points on the
# composite score; task-quality lift is 20, so 6 nudges without bossing). Net-
# positive feedback lowers a model's score (tried earlier), net-negative raises
# it. Smoothed so a single vote barely moves it. Set 0 to disable the nudge.
FEEDBACK_ROUTING_WEIGHT=6
# Only feedback from the last N days counts toward the routing nudge, so a model
# that was bad but has since improved isn't held back by stale votes forever.
FEEDBACK_RECENCY_DAYS=30

# ── Routing health ───────────────────────────────────────────────────────────
# How long to PARK a model whose free-tier DAILY/tier quota is exhausted (a 429
# whose message clearly signals quota/daily, not a transient per-minute limit).
# The router skips a parked model until this lapses, instead of retrying it every
# ~90s all day. Default 6h. A transient 429/timeout still uses the short cooldown.
FEEDER_QUOTA_BENCH_MS=21600000
# Bench a model whose REAL success rate falls below this over >= MIN_ATTEMPTS in
# the 30-min health window (catches intermittent / non-429 failures the
# consecutive-429 path misses). Daily-revived. Defaults 0.15 over 8 attempts.
FEEDER_LOW_SUCCESS_THRESHOLD=0.15
FEEDER_LOW_SUCCESS_MIN_ATTEMPTS=8
# Probe efficiency: capability probes fail fast (8s) rather than the 15s serving
# timeout, and a model that has failed >= N probe attempts in the last H hours is
# skipped (it keeps timing out — don't re-burn a probe sweep on it every start).
PROBE_TIMEOUT_MS=8000
PROBE_FAIL_BACKOFF_N=2
PROBE_FAIL_BACKOFF_HOURS=24
# Swarm provider anti-affinity (for parallel task-runners like RINGER). Comma-
# separated consumer labels whose sessions are spread across distinct platforms
# (one worker per provider) and hold their lane for the job. Only these consumers
# are affected; all other traffic routes normally.
FEEDER_SWARM_CONSUMERS=ringer
# How long a swarm session's platform lane is held after its last call before
# being released (ms). Deliberately LONG: a live-but-slow worker can go minutes
# between calls mid-attempt and must not lose its provider; an over-held lane
# only makes capacity mildly conservative. Refreshed on every call. Default 5min.
FEEDER_SWARM_LANE_IDLE_MS=300000
